# auto-research environment.
#
# Copy this file to `.env` at the repo root and adjust values as needed.
# `docker compose -f build/docker-compose.yml ...` auto-loads `.env`.
#
# All variables are optional; defaults below assume:
#   - You run compose from the repo root (so .. = repo root)
#   - Claude Code is installed via the official installer
#   - Your host UID/GID are 1000/1000

# ── Project layout ───────────────────────────────────────────────────────────
# Absolute path to this repo on the host. Used as the source of every project
# bind mount. If you `docker compose -f build/docker-compose.yml ...` from the
# repo root, the default `..` resolves correctly. Set this if you invoke
# compose from elsewhere.
PROJECT_ROOT=..

# ── Claude Code (host paths) ────────────────────────────────────────────────
# These are the host-side paths. The agents container bind-mounts each into
# /home/ubuntu/ so the in-container claude session shares your auth + history
# with the host.
#
# Required: install Claude Code on the host first (https://claude.ai/code) and
# log in once so .claude / .claude.json exist. Then point these at them.
CLAUDE_HOME=${HOME}/.claude
CLAUDE_CONFIG=${HOME}/.claude.json

# ── User mapping ────────────────────────────────────────────────────────────
# Container processes run as this UID/GID so file writes inside bind mounts
# stay owned by your host user. Run `id -u` / `id -g` on the host to verify.
HOST_UID=1000
HOST_GID=1000
